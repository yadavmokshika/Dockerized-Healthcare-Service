# Copy this file to .env and fill in the values.

ENV=prod
DEBUG=false

# Default model used when none is specified (gemini or groq)
DEFAULT_MODEL=groq

# Google Gemini
# Google Gemini Pro Configuration
GEMINI_API_KEY="hi"
GEMINI_MODEL_NAME=gemini-3.1-pro-preview

# Groq Llama
GROQ_API_KEY="hi"
GROQ_MODEL=llama-3.1-8b-instant

